<Window x:Class="SceneryAddonsBrowser.Views.AddonManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Addon Manager"
        Width="920"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="760"
        MinHeight="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FF252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2A2A2A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2E2E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="B" Property="Background" Value="#FF1A1A1A"/>
                                <Setter Property="Foreground" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Border Background="#FF1E1E1E"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                        Background="#FF252525"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,10"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Addon Manager"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock x:Name="SubtitleTextBlock"
                                       Text="Manage downloaded and installed sceneries"
                                       FontSize="12"
                                       Foreground="#FFB0B0B0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="CheckUpdatesButton"
                                    Content="Check for updates"
                                    Width="150"
                                    Height="30"
                                    Click="CheckUpdates_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- UPDATE BANNER -->
                <Border Grid.Row="1"
                        x:Name="UpdateBanner"
                        Background="#FF2B3A4A"
                        BorderBrush="#FF4FC3F7"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="UpdateBannerText"
                               Foreground="#FFDCEEFF"
                               FontSize="12"/>
                </Border>

                <!-- TABLE -->
                <ListView Grid.Row="2"
                          x:Name="AddonsListView"
                          Background="#FF1E1E1E"
                          BorderBrush="#FF3A3A3A"
                          BorderThickness="1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ICAO" Width="70"
                                            DisplayMemberBinding="{Binding Icao}"/>
                            <GridViewColumn Header="Scenario" Width="240"
                                            DisplayMemberBinding="{Binding ScenarioName}"/>
                            <GridViewColumn Header="Developer" Width="160"
                                            DisplayMemberBinding="{Binding Developer}"/>

                            <GridViewColumn Header="Status" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayStatus}"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFB0B0B0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF4FC3F7"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Installed" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DownloadDate, StringFormat=yyyy-MM-dd}"
                                                   Foreground="#FFB0B0B0"
                                                   FontSize="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="Actions" Width="260">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Update"
                                                    Style="{StaticResource RowActionButton}"
                                                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                                                    Tag="{Binding}"
                                                    Click="Update_Click"/>
                                            <Button Content="Reinstall"
                                                    Style="{StaticResource RowActionButton}"
                                                    Tag="{Binding}"
                                                    Click="Reinstall_Click"/>
                                            <Button Content="Uninstall"
                                                    Style="{StaticResource RowActionButton}"
                                                    IsEnabled="{Binding IsInstalled}"
                                                    Tag="{Binding}"
                                                    Click="Uninstall_Click"/>
                                            <Button Content="Page"
                                                    Style="{StaticResource RowActionButton}"
                                                    Tag="{Binding}"
                                                    Click="OpenPage_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- FOOTER -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FooterCountText"
                               Foreground="#FFB0B0B0"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Close"
                            Width="90"
                            Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
